# Default provider for the instance
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
# For image reading on OpenAI-compatible gateways, switch to a vision-capable model such as gpt-4.1.
AI_MODEL=deepseek-chat

# Server
ADMIN_SECRET=
PORT=3000
# Relative paths are resolved from the repository root.
DATABASE_PATH=./data/database.sqlite

# Remote deployment
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:3000

# Encrypts per-owner custom API keys on the server.
# Use a long random string in production.
USER_API_KEY_ENCRYPTION_SECRET=
