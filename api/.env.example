# AI Provider
# 填入你的 AI API Key（DeepSeek / OpenAI / Anthropic 等均可）
DEEPSEEK_API_KEY=

# AI API 请求地址（默认 DeepSeek；可换成 OpenAI 兼容接口）
OPENAI_BASE_URL=https://api.deepseek.com

# 默认 AI 模型
AI_MODEL=deepseek-chat

# JWT 签名密钥（生产环境必须设置为随机长字符串）
JWT_SECRET=

# 服务监听端口（默认 3000）
PORT=3000

# 数据库文件路径（Docker 部署时建议使用 /app/data/database.sqlite）
DATABASE_PATH=./data/database.sqlite

# 管理后台鉴权密钥（设置后才能访问 /api/admin/* 路由）
ADMIN_SECRET=
