{
  "name": "yinjie-workspace",
  "private": true,
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@yinjie/app --filter=@yinjie/admin",
    "dev:app": "pnpm --filter @yinjie/app dev",
    "dev:admin": "pnpm --filter @yinjie/admin dev",
    "dev:desktop": "pnpm --filter @yinjie/desktop dev",
    "build": "turbo run build --filter=@yinjie/contracts --filter=@yinjie/config --filter=@yinjie/ui --filter=@yinjie/app --filter=@yinjie/admin",
    "build:web": "pnpm build",
    "desktop:build": "pnpm --filter @yinjie/desktop build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "legacy:start": ".\\start.bat",
    "legacy:restart": ".\\restart.bat",
    "legacy:stop": ".\\stop.bat"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.2",
    "typescript": "^5.9.3"
  }
}
