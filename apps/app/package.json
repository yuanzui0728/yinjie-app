{
  "name": "@yinjie/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/dev-services.mjs start app",
    "dev:raw": "vite",
    "dev:stop": "node ../../scripts/dev-services.mjs stop app",
    "dev:restart": "node ../../scripts/dev-services.mjs restart app",
    "dev:status": "node ../../scripts/dev-services.mjs status app",
    "build": "tsc -p tsconfig.app.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor/core": "^7.1.1",
    "@capacitor/keyboard": "^7.0.6",
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-router": "^1.109.2",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.2.5",
    "@yinjie/config": "workspace:*",
    "@yinjie/contracts": "workspace:*",
    "@yinjie/ui": "workspace:*",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.0.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "@yinjie/tooling": "workspace:*",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.15.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.1.0"
  }
}
