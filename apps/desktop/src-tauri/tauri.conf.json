{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yinjie",
  "version": "0.1.0",
  "identifier": "com.yinjie.runtime",
  "build": {
    "beforeDevCommand": "pnpm --dir ../app dev",
    "beforeBuildCommand": "YINJIE_APP_BUILD_BASE=relative pnpm --dir ../app build",
    "devUrl": "http://127.0.0.1:5180",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "隐界",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "transparent": true,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/icon.icns"],
    "externalBin": []
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": []
    }
  }
}
